{
  "manifest_version": 3,
  "name": "Work Log Tracker",
  "version": "1.0",
  "description": "Track your Salesforce work and export monthly reports",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.salesforce.com/*", "https://*.lightning.force.com/*"],
      "js": ["content.js"]
    }
  ]
}